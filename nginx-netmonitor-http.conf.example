# Nginx Configuration for NetMonitor SOC - HTTP-only (pre-SSL)
# Supports both Web Dashboard (8080) and MCP HTTP API (8000)
#
# Dit is de initiële, HTTP-only config die install_complete.sh gebruikt.
# Er zijn bij eerste install nog geen Let's Encrypt certificaten, dus een
# server-block dat al naar /etc/letsencrypt/live/<domein>/... verwijst
# laat "nginx -t" gegarandeerd falen (zie nginx-netmonitor.conf.example).
#
# Na installatie upgrade je naar HTTPS met:
#   sudo certbot --nginx -d soc.example.com
# Certbot's nginx-plugin herschrijft dit bestand dan zelf: het voegt het
# 443-server-block + ssl_certificate-regels toe en zet de HTTP->HTTPS
# redirect op, gebaseerd op nginx-netmonitor.conf.example.

# Upstream voor Web Dashboard (Flask/eventlet/SocketIO)
upstream netmonitor_dashboard {
    server 127.0.0.1:8080 fail_timeout=0;
    keepalive 32;
}

# Upstream voor MCP HTTP API (FastAPI/Uvicorn)
upstream netmonitor_mcp_api {
    server 127.0.0.1:8000 fail_timeout=0;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name soc.example.com;  # WIJZIG NAAR JE DOMEIN

    # Let's Encrypt ACME challenge (nodig voor certbot --nginx)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Client body size
    client_max_body_size 10M;

    # Timeouts
    proxy_connect_timeout 300s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;

    # Logging
    access_log /var/log/nginx/netmonitor_access.log;
    error_log /var/log/nginx/netmonitor_error.log;

    # ==================== MCP HTTP API (POORT 8000) ====================
    # FastAPI/Uvicorn MCP server met token authenticatie
    # OpenAPI docs: /mcp/docs (Swagger UI) en /mcp/redoc (ReDoc)

    # Exact match voor /mcp - DIRECT naar backend /mcp endpoint (GEEN rewrite!)
    location = /mcp {
        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Authorization, Content-Type, Accept, X-Requested-With, X-API-Key" always;
        add_header Access-Control-Max-Age 3600 always;

        if ($request_method = 'OPTIONS') {
            return 204;
        }

        # BELANGRIJK: /mcp suffix - stuurt request naar backend /mcp endpoint
        proxy_pass http://netmonitor_mcp_api/mcp;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-API-Key $http_x_api_key;
        proxy_pass_header Authorization;

        # SSE streaming settings
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_redirect off;
        proxy_read_timeout 86400s;
    }

    # Prefix match voor /mcp/* (docs, health, tools, etc.)
    location /mcp/ {
        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Authorization, Content-Type, Accept, X-Requested-With, X-API-Key" always;
        add_header Access-Control-Max-Age 3600 always;

        if ($request_method = 'OPTIONS') {
            return 204;
        }

        # Rewrite /mcp/docs naar /docs, /mcp/health naar /health, etc.
        rewrite ^/mcp/(.*) /$1 break;

        proxy_pass http://netmonitor_mcp_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-API-Key $http_x_api_key;
        proxy_pass_header Authorization;

        # SSE streaming settings
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_redirect off;
        proxy_read_timeout 86400s;
    }

    # ==================== SENSOR API ENDPOINTS (POORT 8080) ====================
    # Flask dashboard sensor endpoints met sensor token authenticatie

    location /api/sensors/ {
        proxy_pass http://netmonitor_dashboard;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;

        # Preserve Authorization header
        proxy_set_header Authorization $http_authorization;
        proxy_pass_header Authorization;

        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_buffering off;
        proxy_redirect off;
    }

    # ==================== WEB DASHBOARD (POORT 8080) ====================
    # Flask dashboard met Flask-Login authenticatie

    # Kiosk Mode - Public access (GEEN authenticatie vereist)
    location ~ ^/(kiosk|api/kiosk/) {
        proxy_pass http://netmonitor_dashboard;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;
        proxy_redirect off;
    }

    # Login endpoints - GEEN authenticatie vereist
    location ~ ^/(login|api/auth/) {
        proxy_pass http://netmonitor_dashboard;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Cookie passthrough
        proxy_set_header Cookie $http_cookie;
        proxy_pass_header Set-Cookie;

        proxy_buffering off;
        proxy_redirect off;
    }

    # Dashboard root - Flask-Login authenticatie
    location / {
        proxy_pass http://netmonitor_dashboard;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Cookie passthrough
        proxy_set_header Cookie $http_cookie;
        proxy_pass_header Set-Cookie;

        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_buffering off;
        proxy_redirect off;
    }

    # Dashboard API endpoints - Flask-Login authenticatie
    location /api/ {
        proxy_pass http://netmonitor_dashboard;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Cookie passthrough
        proxy_set_header Cookie $http_cookie;
        proxy_pass_header Set-Cookie;

        proxy_buffering off;
        proxy_redirect off;
    }

    # WebSocket endpoint - Flask-Login authenticatie
    location /socket.io/ {
        proxy_pass http://netmonitor_dashboard;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Cookie passthrough
        proxy_set_header Cookie $http_cookie;
        proxy_pass_header Set-Cookie;

        # WebSocket specific
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_buffering off;

        # Longer timeout voor persistent connections
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # Static files
    location /static/ {
        alias /opt/netmonitor/web/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
